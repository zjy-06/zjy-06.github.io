<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>⚠️ 系统崩溃</title>
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js">
    </script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            padding: 20px;
        }
        .phone {
            width: 100%;
            max-width: 420px;
            min-height: 700px;
            background: linear-gradient(145deg, #0d0d1a, #1a0a2e);
            border-radius: 40px;
            padding: 30px 24px 30px;
            position: relative;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.9);
            overflow: hidden;
            border: 1px solid rgba(255, 200, 0, 0.10);
        }
        .page {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 640px;
            animation: fadeIn 0.6s ease;
            position: relative;
            z-index: 2;
        }
        .page.active {
            display: flex;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== 故障特效 ===== */
        #page3 {
            position: relative;
            overflow: hidden;
        }
        .glitch-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
            background: rgba(255, 0, 0, 0);
            animation: none;
        }
        .glitch-overlay.active {
            animation: glitchFlash 0.12s infinite alternate;
        }
        @keyframes glitchFlash {
            0% {
                background: rgba(255, 0, 0, 0.12);
                transform: translate(2px, -2px) scale(1.01);
            }
            25% {
                background: rgba(0, 255, 255, 0.10);
                transform: translate(-3px, 1px) scale(1.02);
            }
            50% {
                background: rgba(255, 0, 255, 0.10);
                transform: translate(4px, 3px) scale(0.99);
            }
            75% {
                background: rgba(255, 255, 0, 0.08);
                transform: translate(-2px, -3px) scale(1.01);
            }
            100% {
                background: rgba(0, 255, 0, 0.08);
                transform: translate(1px, 4px) scale(1);
            }
        }
        .glitch-text {
            font-size: 38px;
            font-weight: 900;
            color: #ffd700;
            text-shadow: 3px 3px 0 #ff0040, -3px -3px 0 #00ccff;
            text-align: center;
            line-height: 1.2;
            position: relative;
            z-index: 2;
            animation: glitchText 0.08s infinite alternate;
            margin-bottom: 6px;
        }
        @keyframes glitchText {
            0% {
                transform: translate(2px, -2px) skewX(2deg);
            }
            25% {
                transform: translate(-3px, 1px) skewX(-3deg);
            }
            50% {
                transform: translate(4px, 3px) skewX(1deg);
            }
            75% {
                transform: translate(-1px, -3px) skewX(-1deg);
            }
            100% {
                transform: translate(1px, 4px) skewX(2deg);
            }
        }
        .result-sub {
            font-size: 20px;
            color: #ff6b9d;
            text-align: center;
            position: relative;
            z-index: 2;
            text-shadow: 0 0 20px rgba(255, 0, 100, 0.3);
            font-weight: 700;
            letter-spacing: 2px;
        }
        .countdown-box {
            margin-top: 28px;
            padding: 12px 28px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
            z-index: 2;
            text-align: center;
        }
        .countdown-box .label {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.25);
            letter-spacing: 3px;
        }
        .countdown-box .number {
            font-size: 52px;
            font-weight: 900;
            color: #ffd700;
            text-shadow: 0 0 40px rgba(255, 200, 0, 0.2);
            line-height: 1.2;
        }

        /* ===== 二维码页面 ===== */
        #page4 .final-title {
            font-size: 28px;
            font-weight: 900;
            color: #ff0040;
            text-shadow: 0 0 40px rgba(255, 0, 64, 0.5);
            text-align: center;
            margin-bottom: 6px;
        }
        #page4 .final-sub {
            font-size: 18px;
            font-weight: 700;
            color: #ffd700;
            text-shadow: 0 0 20px rgba(255, 200, 0, 0.3);
            text-align: center;
            margin-bottom: 18px;
            letter-spacing: 2px;
        }
        .qr-wrapper {
            background: #fff;
            padding: 20px;
            border-radius: 20px;
            box-shadow: 0 0 60px rgba(255, 200, 0, 0.06);
            margin-bottom: 14px;
        }
        #qrcode {
            width: 200px;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        #qrcode img {
            width: 100% !important;
            height: 100% !important;
        }
        #page4 .hint {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.18);
            text-align: center;
            line-height: 1.6;
        }
        #page4 .hint strong {
            color: #ff6b9d;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="phone">

        <!-- ===== 故障页 ===== -->
        <div id="page3" class="page active">
            <div class="glitch-overlay" id="glitchOverlay"></div>
            <div class="glitch-text" id="glitchResult">⚠️ 系 统 崩 溃 ⚠️</div>
            <div class="result-sub" id="resultSub">错 误 代 码 ： 0 x 0 0 0 0 F F</div>
            <div class="countdown-box">
                <div class="label">⚡ 无 法 恢 复 · 核 心 进 程 已 终 止 ⚡</div>
                <div class="number" id="countdownNumber">3</div>
            </div>
        </div>

        <!-- ===== 二维码页 ===== -->
        <div id="page4" class="page">
            <div class="final-title">🔴 你确定吗？</div>
            <div class="final-sub">这是最后的机会 · 一旦开始就无法回头</div>
            <div class="qr-wrapper">
                <div id="qrcode"></div>
            </div>
            <div class="hint">
                👆 扫码领取终极武器 · 拯救地球的最后一步
                <br>
                <span style="font-size:12px; color:rgba(255,255,255,0.10);">（地球的命运在你手中）</span>
            </div>
        </div>

    </div>

    <script>
        // ============================================================
        //  故障页 + 倒计时 → 自动跳转二维码
        // ============================================================
        let countdownTimer = null;

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('glitchOverlay').classList.add('active');

            let count = 3;
            const numEl = document.getElementById('countdownNumber');
            numEl.textContent = count;

            countdownTimer = setInterval(() => {
                count--;
                if (count <= 0) {
                    clearInterval(countdownTimer);
                    countdownTimer = null;
                    document.getElementById('glitchOverlay').classList.remove('active');
                    document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
                    document.getElementById('page4').classList.add('active');
                    generateQR();
                } else {
                    numEl.textContent = count;
                }
            }, 1000);
        });

        // ============================================================
        //  二维码（应用宝 · 反诈中心）
        // ============================================================
        let qrGenerated = false;

        function generateQR() {
            if (qrGenerated) return;
            qrGenerated = true;
            const url = 'https://sj.qq.com/appdetail/com.hicorenational.antifraud';
            const container = document.getElementById('qrcode');
            container.innerHTML = '';
            new QRCode(container, {
                text: url,
                width: 200,
                height: 200,
                colorDark: '#0a0a0a',
                colorLight: '#ffffff',
                correctLevel: QRCode.CorrectLevel.H
            });
        }
    </script>

</body>
</html>
