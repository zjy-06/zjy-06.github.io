            margin-bottom: 18px;
            letter-spacing: 1px;
        }
        .flyer-box {
            width: 100%;
            background: rgba(255, 215, 0, 0.04);
            border-radius: 16px;
            padding: 20px 22px;
            border: 1px solid rgba(255, 215, 0, 0.1);
