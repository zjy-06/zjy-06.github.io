        /* ===== 传单页面 ===== */
        #page7 .flyer-icon {
            font-size: 72px;
            margin-bottom: 10px;
        }
        #page7 .flyer-title {
            font-size: 22px;
            font-weight: 900;
            color: #ffd700;
            text-shadow: 0 0 40px rgba(255, 200, 0, 0.3);
            text-align: center;
            margin-bottom: 4px;
        }
        #page7 .flyer-sub {
            font-size: 15px;
