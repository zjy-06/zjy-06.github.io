    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            padding: 20px;
        }
        .phone {
            width: 100%;
            max-width: 420px;
            min-height: 700px;
            background: linear-gradient(145deg, #0d0d1a, #1a0a2e);
            border-radius: 40px;
            padding: 30px 24px 30px;
            position: relative;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.9);
            overflow: hidden;
            border: 1px solid rgba(100, 200, 255, 0.10);
        }
        .page {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 640px;
            animation: fadeIn 0.8s ease;
            position: relative;
            z-index: 2;
        }
        .page.active {
            display: flex;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* ===== 页面1：恭喜抵达 ===== */
        #page1 .glow-text {
            font-size: 28px;
            font-weight: 900;
            color: #fff;
            text-shadow: 0 0 40px rgba(100, 200, 255, 0.4), 0 0 80px rgba(100, 200, 255, 0.15);
            text-align: center;
            line-height: 1.5;
            margin-bottom: 8px;
        }
        #page1 .glow-text .highlight {
            color: #64c8ff;
        }
        #page1 .sub-text {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.5);
            text-align: center;
            line-height: 1.8;
            margin-bottom: 20px;
            letter-spacing: 1px;
        }
        #page1 .sub-text .emoji-big {
            font-size: 72px;
            display: block;
            margin: 10px auto 8px;
        }
        .loading-dots::after {
            content: '';
            animation: dots 1.5s infinite;
        }
        @keyframes dots {
            0% { content: ''; }
            33% { content: '.'; }
            66% { content: '..'; }
            100% { content: '...'; }
        }
        .progress-bar {
            width: 80%;
            height: 4px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 4px;
            margin-top: 10px;
            overflow: hidden;
        }
        .progress-bar .fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #64c8ff, #ffd700);
            border-radius: 4px;
            animation: progressAnim 5s ease forwards;
        }
        @keyframes progressAnim {
            0% { width: 0%; }
            100% { width: 100%; }
        }

        /* ===== 页面2：发现星球 ===== */
        #page2 .discover-icon {
            font-size: 80px;
            margin-bottom: 16px;
        }
        #page2 .discover-title {
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            text-align: center;
            margin-bottom: 10px;
        }
        #page2 .discover-title .highlight {
            color: #64c8ff;
        }
        #page2 .discover-desc {
            font-size: 15px;
            color: rgba(255, 255, 255, 0.45);
            text-align: center;
            line-height: 1.8;
            margin-bottom: 20px;
            letter-spacing: 1px;
        }
        .diary-btn {
            padding: 14px 40px;
            background: rgba(100, 200, 255, 0.08);
            border: 1px solid rgba(100, 200, 255, 0.2);
            border-radius: 14px;
            color: #64c8ff;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            font-family: inherit;
            letter-spacing: 2px;
        }
        .diary-btn:hover {
            background: rgba(100, 200, 255, 0.15);
            transform: scale(1.02);
            box-shadow: 0 0 40px rgba(100, 200, 255, 0.05);
        }
        .diary-btn:active {
            transform: scale(0.95);
        }

        /* ===== 日记页面 ===== */
        .diary-page {
            width: 100%;
        }
        .diary-date {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.2);
            letter-spacing: 3px;
            margin-bottom: 4px;
            text-align: center;
        }
        .diary-title {
            font-size: 18px;
            font-weight: 700;
            color: #64c8ff;
            text-align: center;
            margin-bottom: 16px;
            text-shadow: 0 0 30px rgba(100, 200, 255, 0.1);
        }
        .diary-box {
            width: 100%;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 20px 22px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            margin-bottom: 16px;
            min-height: 300px;
            max-height: 400px;
            overflow-y: auto;
        }
        .diary-box p {
            color: rgba(255, 255, 255, 0.78);
            font-size: 15px;
            line-height: 1.9;
            margin-bottom: 12px;
            letter-spacing: 0.5px;
        }
        .diary-box p:last-child {
            margin-bottom: 0;
        }
        .diary-box .highlight-text {
            color: #64c8ff;
            font-weight: 600;
        }
        .diary-box .gold-text {
            color: #ffd700;
            font-weight: 600;
        }
        .diary-box .warning-text {
            color: #ff6b9d;
            font-weight: 600;
        }
        .diary-box .monster-text {
            color: #ff0040;
            font-weight: 700;
            font-size: 16px;
        }
        .diary-box .green-text {
            color: #00ffc8;
            font-weight: 600;
        }
        .diary-page-num {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.08);
            letter-spacing: 4px;
            margin-top: 4px;
        }
        .diary-next-btn {
            padding: 12px 32px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 20px;
            color: rgba(255, 255, 255, 0.3);
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
            font-family: inherit;
            letter-spacing: 1px;
        }
        .diary-next-btn:hover {
            background: rgba(255, 255, 255, 0.08);
            color: rgba(255, 255, 255, 0.5);
        }
        .diary-next-btn.urgent {
            border-color: rgba(255, 0, 64, 0.2);
            color: #ff6b9d;
        }
        .diary-next-btn.urgent:hover {
