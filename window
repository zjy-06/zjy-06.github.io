            line-height: 1.9;
            margin-bottom: 10px;
        }
        .flyer-box p:last-child {
            margin-bottom: 0;
        }
        .flyer-box .big-text {
            font-size: 22px;
            font-weight: 900;
            color: #ffd700;
        }
        .flyer-box .red-text {
            color: #ff0040;
            font-weight: 700;
        }
        .flyer-box .blue-text {
            color: #64c8ff;
            font-weight: 600;
        }
        .flyer-btn {
            display: inline-block;
            padding: 16px 40px;
            background: linear-gradient(135deg, #ffd700, #f5a623);
            color: #0a0a0a;
            font-size: 18px;
            font-weight: 700;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
            letter-spacing: 2px;
