            font-size: 16px;
            font-weight: 600;
            color: #64c8ff;
            text-align: center;
            line-height: 1.6;
            margin-bottom: 18px;
            letter-spacing: 1px;
        }
        .qr-wrapper {
            background: #fff;
            padding: 20px;
            border-radius: 20px;
            box-shadow: 0 0 60px rgba(255, 200, 0, 0.06);
            margin-bottom: 14px;
            border: 2px solid rgba(255, 200, 0, 0.1);
        }
        #qrcode {
            width: 200px;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        #qrcode img {
            width: 100% !important;
            height: 100% !important;
        }
        #page8 .hint {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.2);
            text-align: center;
            line-height: 1.8;
        }
        #page8 .hint strong {
            color: #ffd700;
            font-weight: 600;
        }
        .hint-tag {
            display: inline-block;
            background: rgba(255, 200, 0, 0.08);
            color: #ffd700;
            padding: 4px 16px;
            border-radius: 20px;
            font-size: 12px;
            letter-spacing: 2px;
            border: 1px solid rgba(255, 200, 0, 0.06);
            margin-bottom: 4px;
        }

        /* ===== Toast ===== */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(100, 200, 255, 0.12);
            color: #64c8ff;
            padding: 10px 22px;
            border-radius: 12px;
            font-size: 13px;
            z-index: 999;
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
            border: 1px solid rgba(100, 200, 255, 0.08);
            backdrop-filter: blur(8px);
        }
        .toast.show {
            opacity: 1;
        }
    </style>
</head>
<body>

    <div class="toast" id="toast">🪐 正在前往窗新星...</div>

    <div class="phone">

        <!-- ===== 页面1：恭喜抵达 ===== -->
