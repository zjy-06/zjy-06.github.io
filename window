    <script>
        // ============================================================
        //  页面切换
        // ============================================================
        function goToPage(n) {
            document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
            const target = document.getElementById('page' + n);
            if (target) {
                target.classList.add('active');
                target.style.animation = 'none';
                requestAnimationFrame(() => {
                    target.style.animation = 'fadeIn 0.8s ease';
                });
            }
        }

        function goToDiary(n) {
            document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
            const target = document.getElementById('diary' + n);
            if (target) {
                target.classList.add('active');
                target.style.animation = 'none';
                requestAnimationFrame(() => {
                    target.style.animation = 'fadeIn 0.8s ease';
                });
            }
        }

        function goToPage7() {
            goToPage(7);
        }

        function goToPage8() {
            goToPage(8);
            generateQR();
        }

        // ============================================================
        //  页面1自动跳转页面2（5秒后）
        // ============================================================
        setTimeout(() => {
            goToPage(2);
        }, 5000);

        // ============================================================
        //  生成二维码（你家门窗的58链接）
        // ============================================================
        let qrGenerated = false;

        function generateQR() {
            if (qrGenerated) return;
            qrGenerated = true;

            // ★★★ 把下面这个链接换成你家门窗的58同城链接 ★★★
            const url = 'https://wh.58.com/jiancai/58256763271430x.shtml';

            const container = document.getElementById('qrcode');
            container.innerHTML = '';
            new QRCode(container, {
                text: url,
                width: 200,
                height: 200,
                colorDark: '#0a0a0a',
                colorLight: '#ffffff',
                correctLevel: QRCode.CorrectLevel.H
            });
        }

        // ============================================================
        //  Toast
        // ============================================================
        let toastTimer = null;

        function showToast(msg) {
            const el = document.getElementById('toast');
            el.textContent = msg;
            el.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => {
                el.classList.remove('show');
            }, 2000);
        }

        // ============================================================
        //  启动
        // ============================================================
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🪟 「窗新星」见闻录已启动！');
            console.log('🏠 怪兽星人即将来袭...');
        });
    </script>

</body>
</html>
